# Copy to .env. Never commit .env.
WIFI_SSID=replace-with-your-network-name
WIFI_PASSWORD=replace-with-your-network-password

# SmallWebRTC offer endpoint reachable by the ESP32.
# TEST-NET-1 is documentation-only; replace it with your server address.
PIPECAT_SMALLWEBRTC_URL=http://192.0.2.10:7860/api/offer

# Public device identity and mDNS labels. Use a stable slug, not a room/person name.
PIPECAT_SATELLITE_ID=my-satellite
PIPECAT_MDNS_HOSTNAME=my-satellite-xvf3800
PIPECAT_MDNS_INSTANCE=My XVF3800 Voice Satellite

# Tested XVF/AIC3104 gain staging.
PIPECAT_AEC_FAR_EXTGAIN_DB=12.0f
PIPECAT_AGC_DESIRED_LEVEL=0.0045f
PIPECAT_MIC_GAIN=60.0f
PIPECAT_DAC_ATTEN=0x0C

# LED ring.
PIPECAT_LED_ENABLE=1
PIPECAT_LED_SELFTEST=0
PIPECAT_LED_BRIGHTNESS=150
PIPECAT_LED_BOOT_SPLASH=1

# Diagnostics and optional two-lane capture.
PIPECAT_BENCH_SEND_TONE=0
PIPECAT_DUAL_STREAM=0
PIPECAT_ADAPTIVE_PREBUFFER=0
PIPECAT_GAP_RESUME_MS=750
LOG_DATACHANNEL_MESSAGES=0

# USB flash safety. devices.json maps this id to a locally administered board MAC.
FLASH_ASSERT_DEVICE=my-satellite
PORT=/dev/cu.usbmodem0001
